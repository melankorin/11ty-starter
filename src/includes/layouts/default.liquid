<!DOCTYPE html>
<html{% if html_classes %} class="{{ html_classes }}"{% endif %} lang="{{ site.lang }}">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="generator" content="{{ eleventy.generator }}">

    <title>{{ title | default: site.title }}</title>
    <meta name="author" content="{{ site.author }}">
    <meta name="description" content="{{ description | default: site.description }}">
    <meta name="theme-color" content="{{ theme_colour | default: site.theme_colour }}">
    <link rel="canonical" href="{{ site.url }}{{ page.url }}">
    
    <link rel="icon" href="/favicon.ico" sizes="32x32">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="manifest" href="/site.webmanifest">
    <meta name="apple-mobile-web-app-title" content="{{ site.title }}" />

    {% if stylesheets %}
        {% for stylesheet in stylesheets %}
            <link rel="stylesheet" href="{{ stylesheet.src }}">
        {% endfor %}
    {% endif %}

    {% if head_scripts %}
        {% for script in head_scripts %}
            <script
                {% if script.defer %}defer{% endif %}
                {% if script.async %}async{% endif %}
                src="{{ script.src }}"></script>
        {% endfor %}
    {% endif %}

    {% if og_src %}
        {% ogImage og_src, og_data  %}
    {% endif %}

    {% comment %} 
    <meta property="og:title" content="{{ site.title }}">
    <meta property="og:url" content="{{ site.url }}{{ page.url }}">
    <meta property="og:description"  content="{{ site.description }}">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="{{ site.title }}">
    <meta property="og:locale" content="{{ site.locale }}">
    <meta property="og:image" content="{{ site.url }}/assets/img/common/og.png">
    <meta property="og:image:type" content="image/png">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:alt" content="Alt text for the Open Graph image">
    {% endcomment %}

    {% comment %}
    <meta name="twitter:card" content="summary_large_image">
    <meta property="twitter:domain" content="{{ site.url | remove: "https://" }}">
    <meta property="twitter:url" content="{{ site.url }}{{ page.url }}">
    <meta name="twitter:title" content="{{ site.title }}">
    <meta name="twitter:description" content="{{ site.description }}">
    <meta name="twitter:image" content="{{ site.url }}/assets/img/common/og.png">
    {% endcomment %}

</head>

<body{% if body_classes %} class="{{ body_classes }}"{% endif %}>

    {{ content }}

    {% if body_scripts %}
        {% for script in body_scripts %}
            <script
                {% if script.defer %}defer{% endif %}
                {% if script.async  %}async{% endif %}
                src="{{ script.src }}"></script>
        {% endfor %}
    {% endif %}

</body>

</html>