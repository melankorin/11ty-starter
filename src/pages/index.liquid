---
layout: layouts/default.liquid
permalink: /
body_scripts:
  - src: /assets/js/main.js
stylesheets:
  - src: /assets/css/style.css
og_src: ./meta/og/og.html
og_data:
  title: index
---
<h1>{{ site.title }}</h1>
<p>{{ site.description  }}</p>

<h2>Blog posts</h2>
<ul>
    {% for post in collections.blog %}
        <li><a href="{{ post.url }}">{{ post.fileSlug | replace: "-", " " | capitalize }}</a></li>
    {% endfor %}
</ul>