{
  "name": "11ty-starter",
  "version": "1.0.0",
  "scripts": {
    "clean:site": "rimraf site",
    "clean:cache": "rimraf .cache",
    "watch:css": " ",
    "watch:js": "esbuild src/js/*.js --bundle --outdir=site/assets/js --watch --sourcemap",
    "watch:eleventy": "eleventy --serve",
    "build:css": " ",
    "build:js": "esbuild src/js/*.js --bundle --outdir=site/assets/js --minify",
    "build:eleventy": "eleventy",
    "build:gulp": "gulp",
    "start": "npm-run-all clean:site -p watch:*",
    "build": "npm-run-all clean:site build:css build:js build:eleventy build:gulp"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@11ty/eleventy-img": "^6.0.4",
    "eleventy-plugin-og-image": "^4.2.1",
    "esbuild": "^0.27.4",
    "fs-extra": "^11.3.4",
    "gulp": "^5.0.1",
    "gulp-hash-src": "^0.1.6",
    "gulp-html-minifier-terser": "^8.0.0",
    "js-yaml": "^4.1.1",
    "luxon": "^3.7.2",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.3"
  }
}
