{
  "name": "11ty-starter",
  "version": "1.0.0",
  "scripts": {
    "watch:js": "esbuild src/js/*.js --bundle --outdir=site/assets/js --watch",
    "watch:eleventy": "eleventy --serve",
    "build:js": "esbuild src/js/*.js --bundle --outdir=site/assets/js --minify",
    "build:eleventy": "eleventy",
    "start": "npm-run-all -p watch:*",
    "build": "npm-run-all build:css build:js build:eleventy build:gulp"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "esbuild": "^0.27.4",
    "js-yaml": "^4.1.1",
    "npm-run-all": "^4.1.5"
  }
}
